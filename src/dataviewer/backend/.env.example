# HMI Backend Environment Configuration
# Copy this file to .env and fill in your local values.

# Path to the directory containing datasets.
# Each subdirectory is treated as a dataset_id.
# Relative paths are resolved from this file's directory (backend/).
HMI_DATA_PATH=../../../datasets

# Dataset ID used by integration tests.
TEST_DATASET_ID=my_dataset

# ============================================================================
# Authentication (WS-20)
# ============================================================================

# Set to "true" to disable authentication and CSRF checks in local development.
# NEVER enable this in production.
DATAVIEWER_AUTH_DISABLED=true

# Set to "true" when the server is behind HTTPS (marks the csrf_token cookie Secure).
# Always set this to "true" in production.
DATAVIEWER_SECURE_COOKIES=false

# Authentication provider: "apikey" (default), "azure_ad", or "auth0".
DATAVIEWER_AUTH_PROVIDER=apikey

# --- API key provider ---
# Secret key that clients must send in the X-API-Key header.
DATAVIEWER_API_KEY=

# --- Azure AD / Entra ID provider (DATAVIEWER_AUTH_PROVIDER=azure_ad) ---
# Azure tenant ID (GUID).
DATAVIEWER_AZURE_TENANT_ID=
# Azure AD application (client) ID used as the JWT audience.
DATAVIEWER_AZURE_CLIENT_ID=

# --- Auth0 provider (DATAVIEWER_AUTH_PROVIDER=auth0) ---
# Auth0 tenant domain, e.g. "your-tenant.us.auth0.com".
DATAVIEWER_AUTH0_DOMAIN=
# Auth0 API audience (identifier), e.g. "https://api.dataviewer.example.com".
DATAVIEWER_AUTH0_AUDIENCE=
